#!/usr/bin/expect -f
set timeout 10
spawn ssh -o StrictHostKeyChecking=no admin@192.168.1.189
expect "password:"
send "C!sco#123\r"

expect {
    ">" {
        send "show version\r"
        expect ">"
    }
    "~ $" {
        send "uname -a; cat /etc/os-release\r"
        expect "~ $"
        send "cat /home/admin/clarion/lab/orchestrator_config.json | grep -A 10 runner-6\r"
        expect "~ $"
        send "cat /var/log/clarion_lab/orchestrator.log | tail -n 50\r"
        expect "~ $"
    }
    "$" {
        send "uname -a\r"
        expect "$"
    }
}
send "exit\r"
expect eof
